# Database
DATABASE_URL=postgresql://user:password@localhost:5432/effectlab

# Better Auth
BETTER_AUTH_API_KEY="your-api-key"
BETTER_AUTH_SECRET=your-secret-key-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3000

# Comma-separated list of additional origins that can reach Better Auth
# state-changing endpoints (sign-in, sign-up, sign-out, etc.). Each entry
# is normalized to "<protocol>//<host>", and BETTER_AUTH_URL +
# NEXT_PUBLIC_APP_URL are always included automatically. Use this to add
# custom domains (e.g. production site behind a domain alias).
#   e.g. BETTER_AUTH_TRUSTED_ORIGINS=https://www.example.com,https://staging.example.com
BETTER_AUTH_TRUSTED_ORIGINS=

# OAuth (optional for local dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Upstash Redis (rate limits + cached entitlements)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Public app URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Observability / analytics
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
