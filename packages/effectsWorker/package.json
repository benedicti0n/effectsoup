{
  "name": "@effectsoup/worker",
  "version": "0.1.1",
  "type": "module",
  "description": "Browser Web Worker communication layer for image effects",
  "license": "MIT",
  "author": "benedicti0n",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benedicti0n/effectsoup.git",
    "directory": "packages/effectsWorker"
  },
  "bugs": {
    "url": "https://github.com/benedicti0n/effectsoup/issues"
  },
  "homepage": "https://github.com/benedicti0n/effectsoup#readme",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "import": "./dist/worker.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "dependencies": {
    "@effectsoup/core": "workspace:*",
    "@effectsoup/presets": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/node": "^22.13.0",
    "eslint": "^9.19.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.22.0",
    "vitest": "^3.0.5"
  }
}
